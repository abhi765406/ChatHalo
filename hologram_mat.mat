material {
    name : hologram,
    requires : [
        color,
        uv0,
    ],
    shadingModel : unlit,
    blending : transparent,
    culling : none,
    doubleSided : true,
    parameters : [
        {
            type : samplerExternal,
            name : videoTexture
        }
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        
        vec2 uv = getUV0();
        // The texture is usually flipped or rotated, we might need to adjust uv
        
        vec4 color = texture(materialParams_videoTexture, uv);
        
        // Hologram effect
        float scanline = sin(uv.y * 100.0) * 0.1 + 0.9;
        
        vec3 finalColor = color.rgb * vec3(0.5, 0.8, 1.0) * scanline; // Cyan/blue tint
        
        // Edge glow / basic alpha: we use the luminance of the video as alpha
        float lum = dot(color.rgb, vec3(0.299, 0.587, 0.114));
        float alpha = lum * 1.5;
        
        material.baseColor = vec4(finalColor, min(alpha, 1.0));
    }
}
